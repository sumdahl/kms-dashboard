{
  "name": "kms-dashboard",
  "version": "1.0.0",
  "description": "Key Management System Dashboard",
  "scripts": {
    "copy-lucide": "cp node_modules/lucide/dist/umd/lucide.min.js static/js/lucide.min.js",
    "copy-htmx": "cp node_modules/htmx.org/dist/htmx.min.js static/js/htmx.min.js",
    "build:css": "postcss src/styles/input.css -o static/css/output.css",
    "watch:css": "postcss src/styles/input.css -o static/css/output.css --watch",
    "dev": "cargo watch -q -c -w src -w templates -s \"npm run build:css\" -x run"
  },
  "dependencies": {
    "htmx.org": "^2.0.4",
    "lucide": "^0.475.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "postcss": "^8.5.0",
    "postcss-cli": "^11.0.0",
    "tailwindcss": "^4.2.2"
  },
  "keywords": [
    "KMS"
  ],
  "author": "Sumiran Dahal, Pradeep Karki",
  "license": "MIT"
}
